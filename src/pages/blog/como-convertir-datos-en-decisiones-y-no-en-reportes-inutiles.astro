---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout
  title="LiderazgoTech | Como convertir datos en decisiones y no en reportes inutiles"
  metaDescription="Convierte datos en decisiones de negocio con indicadores claros, dashboards utiles y analisis libre de ruido operativo."
>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="w-full pt-24 md:pt-32 bg-[#1A1A1A] text-white">
      <div class="grid grid-cols-1 lg:grid-cols-12 lg:min-h-[614px]">
        <div
          class="lg:col-span-7 flex flex-col justify-center p-6 md:p-16 bg-[#FFCC00] text-[#1A1A1A] border-b-4 lg:border-b-0 lg:border-r-4 border-[#1A1A1A]"
        >
          <div class="mb-6 flex flex-wrap items-center gap-4">
            <span
              class="bg-[#1A1A1A] text-[#FFCC00] px-3 py-1 font-key-concept text-sm md:text-base"
            >
              INTELIGENCIA DE NEGOCIO
            </span>
            <span class="font-key-concept text-xs md:text-sm opacity-70">
              REF: LT-2026-BI
            </span>
          </div>
          <h1
            class="font-headline-xl text-4xl md:text-6xl lg:text-7xl uppercase mb-8 leading-none tracking-tighter"
          >
            Como convertir datos en decisiones y no en reportes inutiles
          </h1>

          <div
            class="grid grid-cols-2 sm:grid-cols-4 gap-6 border-t-2 border-[#1A1A1A] pt-8"
          >
            <div>
              <p
                class="font-label text-[10px] md:text-xs opacity-60 uppercase mb-1"
              >
                FECHA
              </p>
              <p class="font-key-concept text-sm md:text-base font-bold">
                MAY 06, 2026
              </p>
            </div>
            <div>
              <p
                class="font-label text-[10px] md:text-xs opacity-60 uppercase mb-1"
              >
                AUTOR
              </p>
              <p class="font-key-concept text-sm md:text-base font-bold">
                ING. CHRISTIAN PICOS
              </p>
            </div>
            <div>
              <p
                class="font-label text-[10px] md:text-xs opacity-60 uppercase mb-1"
              >
                ESTADO
              </p>
              <p class="font-key-concept text-sm md:text-base font-bold">
                PUBLICADO
              </p>
            </div>
            <div>
              <p
                class="font-label text-[10px] md:text-xs opacity-60 uppercase mb-1"
              >
                LEER
              </p>
              <p class="font-key-concept text-sm md:text-base font-bold">
                10 MIN
              </p>
            </div>
          </div>
        </div>

        <div
          class="lg:col-span-5 h-[300px] lg:h-auto relative grayscale overflow-hidden"
        >
          <img
            alt="Pantallas de analitica empresarial mostrando indicadores para toma de decisiones"
            class="w-full h-full object-cover"
            src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=1200&q=80"
          />
        </div>
      </div>
    </section>

    <!-- Article Body -->
    <section
      class="max-w-7xl mx-auto px-6 md:px-12 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-12 gap-12"
    >
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-32 space-y-12">
          <div class="border-l-4 border-[#FFCC00] pl-6">
            <h4 class="font-key-concept text-sm mb-4 uppercase font-black">
              CONTENIDO
            </h4>
            <ul
              class="space-y-4 font-label text-xs uppercase tracking-widest font-bold"
            >
              <li>
                <a class="hover:text-[#FFCC00] transition-colors" href="#ruido"
                  >01. DATOS SIN DECISION</a>
              </li>
              <li>
                <a class="hover:text-[#FFCC00] transition-colors" href="#claridad"
                  >02. CLARIDAD OPERATIVA</a>
              </li>
              <li>
                <a class="hover:text-[#FFCC00] transition-colors" href="#sesgo"
                  >03. SESGO DE ANALISIS</a>
              </li>
              <li>
                <a class="hover:text-[#FFCC00] transition-colors" href="#accion"
                  >04. DECISION ACCIONABLE</a>
              </li>
            </ul>
          </div>
          <div
            class="bg-[#1A1A1A] p-6 text-[#FFCC00] border-t-4 border-[#FFCC00]"
          >
            <span class="material-symbols-outlined mb-4">query_stats</span>
            <p class="font-label text-xs uppercase leading-tight font-bold">
              Herramientas recomendadas para BI, modelado de datos,
              indicadores ejecutivos y gobierno de metricas
            </p>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <article class="lg:col-span-9 max-w-full lg:max-w-3xl">
        <div class="mb-16" id="ruido">
          <h2
            class="text-3xl md:text-4xl font-black uppercase mb-8 leading-none"
          >
            01. MUCHOS DATOS NO SIGNIFICAN MEJORES DECISIONES
          </h2>
          <div
            class="font-serif text-lg md:text-xl leading-relaxed text-[#333] space-y-6"
          >
            <p>
              Muchas empresas creen que tener mas reportes equivale a tener mas
              inteligencia. El resultado suele ser el contrario: dashboards
              elegantes, graficas saturadas y tableros que se ven modernos pero
              no responden una pregunta operativa concreta. Cuando el dato no
              cambia una decision, solo aumenta el ruido.
            </p>
            <p>
              La inteligencia de negocio no consiste en mostrar todo lo que se
              puede medir. Consiste en seleccionar los indicadores que explican
              la operacion real, detectar desviaciones y permitir que una
              persona actue con menos incertidumbre. Un reporte inutil no falla
              por feo: falla porque no tiene consecuencia.
            </p>
          </div>
        </div>

        <div
          class="bg-[#FFCC00] p-8 md:p-12 border-4 border-[#1A1A1A] my-16 relative overflow-hidden"
        >
          <span
            class="material-symbols-outlined absolute -right-4 -bottom-4 text-8xl opacity-10"
            >terminal</span
          >
          <h3 class="font-key-concept text-sm md:text-base mb-4 font-black">
            TECHNICAL INSIGHT: BUSINESS INTELLIGENCE
          </h3>
          <p
            class="text-2xl md:text-3xl font-black text-[#1A1A1A] italic leading-tight"
          >
            "Un dashboard valioso no impresiona por la cantidad de graficas:
            cambia la velocidad y calidad de una decision."
          </p>
        </div>

        <div class="mb-16" id="claridad">
          <h2 class="text-3xl md:text-4xl font-black uppercase mb-8 leading-none">
            02. DISENAR INDICADORES PARA VER LA OPERACION REAL
          </h2>
          <div
            class="font-slab text-body-lg leading-relaxed text-[#333] space-y-6"
          >
            <p>
              La visualizacion debe empezar por una pregunta de negocio: que
              necesitamos decidir, con que frecuencia y que accion se espera al
              detectar una variacion. Sin esa definicion, el equipo termina
              midiendo lo disponible en lugar de medir lo importante.
            </p>
            <ul class="list-none space-y-4">
              <li class="flex items-start gap-4">
                <span class="bg-[#1A1A1A] text-white p-1 text-xs font-bold"
                  >01</span
                >
                <span
                  >Prioriza metricas accionables: margen, conversion, tiempo de
                  ciclo, cumplimiento, capacidad, costo y calidad.</span
                >
              </li>
              <li class="flex items-start gap-4">
                <span class="bg-[#1A1A1A] text-white p-1 text-xs font-bold"
                  >02</span
                >
                <span
                  >Reduce adornos visuales que no agregan lectura. Claridad
                  supera complejidad cuando el negocio necesita actuar rapido.</span
                >
              </li>
              <li class="flex items-start gap-4">
                <span class="bg-[#1A1A1A] text-white p-1 text-xs font-bold"
                  >03</span
                >
                <span
                  >Define responsables por indicador para que cada desviacion
                  tenga dueno, contexto y siguiente paso.</span
                >
              </li>
            </ul>
          </div>
        </div>

        <!-- Graphic Placeholder / Technical Visual -->
        <div class="industrial-border p-8 bg-white my-16">
          <div class="flex justify-between items-end mb-8">
            <div>
              <p
                class="font-key-concept text-key-concept text-[#FFCC00] bg-[#1A1A1A] px-2 py-1 inline-block mb-2"
              >
                FIG. 11-BI
              </p>
              <h4 class="font-headline-md text-2xl uppercase">
                MATRIZ DE DECISION OPERATIVA
              </h4>
            </div>
            <span class="material-symbols-outlined text-4xl" data-icon="analytics"
              >analytics</span
            >
          </div>
          <div
            class="h-64 w-full bg-[#f0eded] border-2 border-dashed border-[#1A1A1A] flex items-center justify-center"
          >
            <div class="text-center">
              <span
                class="material-symbols-outlined text-6xl opacity-20"
                data-icon="monitoring">monitoring</span
              >
              <p class="font-label text-label uppercase mt-4">
                Relacion entre pregunta de negocio, indicador, responsable,
                umbral y accion esperada
              </p>
            </div>
          </div>
        </div>

        <div class="mb-16" id="sesgo">
          <h2 class="text-3xl md:text-4xl font-black uppercase mb-8 leading-none">
            03. CONTROLAR EL SESGO ANTES DE CONSTRUIR CONCLUSIONES
          </h2>
          <div
            class="font-slab text-body-lg leading-relaxed text-[#333] space-y-6"
          >
            <p>
              Un reporte puede confirmar una idea equivocada si el analisis
              parte de una pregunta sesgada. Elegir solo ciertos periodos,
              excluir excepciones incomodas o comparar unidades distintas puede
              producir una narrativa convincente y, al mismo tiempo, falsa para
              la operacion.
            </p>
            <p>
              El trabajo del analista no es decorar tendencias, sino proteger la
              calidad de la decision. Eso implica documentar definiciones,
              mostrar limites del dato, separar correlacion de causalidad y
              mantener neutralidad incluso cuando el resultado contradice una
              hipotesis ejecutiva.
            </p>
          </div>
        </div>

        <div class="mb-16" id="accion">
          <h2 class="text-3xl md:text-4xl font-black uppercase mb-8 leading-none">
            04. CONVERTIR REPORTES EN ACCIONES DE NEGOCIO
          </h2>
          <div
            class="font-slab text-body-lg leading-relaxed text-[#333] space-y-6"
          >
            <p>
              Un buen tablero debe responder tres preguntas sin explicaciones
              largas: que esta pasando, por que importa y que deberia hacerse
              ahora. Si el usuario necesita una reunion completa para entender
              el reporte, probablemente el diseno no esta apoyando la decision.
            </p>
            <p>
              Para analistas de datos, lideres de area y clientes que buscan
              servicios de inteligencia de negocio, la meta no es producir mas
              pantallas. La meta es construir una version simple, confiable y
              accionable de la realidad operativa. Cuando el dato reduce dudas,
              anticipa problemas y orienta prioridades, deja de ser reporte y se
              convierte en direccion.
            </p>
          </div>
        </div>
      </article>
    </section>

    <!-- Related Posts -->
    <section
      class="bg-[#1A1A1A] text-white py-16 px-6 md:px-12 border-t-4 border-[#FFCC00]"
    >
      <div class="max-w-7xl mx-auto">
        <div
          class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-4"
        >
          <h2 class="text-3xl md:text-5xl font-black uppercase leading-none">
            Documentacion <br class="md:hidden" /> Relacionada
          </h2>
          <span class="material-symbols-outlined text-5xl text-[#FFCC00]"
            >database</span
          >
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div
            class="bg-[#2A2A2A] border-2 border-white/10 p-8 hover:border-[#FFCC00] transition-all group"
          >
            <p
              class="font-key-concept text-[#FFCC00] text-xs mb-4 font-bold tracking-tighter"
            >
              EFICIENCIA IT
            </p>
            <h3
              class="text-xl font-black uppercase mb-6 group-hover:text-[#FFCC00] leading-tight"
            >
              El lado oculto de IT: como aumentar ingresos sin vender mas
            </h3>
            <a
              class="inline-flex items-center gap-2 text-xs uppercase tracking-widest border-b-2 border-[#FFCC00] pb-1 font-bold"
              href="/blog/el-lado-oculto-de-it-como-aumentar-ingresos-sin-vender-mas"
            >
              ACCEDER <span class="material-symbols-outlined text-sm"
                >arrow_forward</span
              >
            </a>
          </div>

          <div
            class="bg-[#2A2A2A] industrial-border border-white/20 p-8 hover:border-[#FFCC00] transition-colors group"
          >
            <p class="font-key-concept text-[#FFCC00] mb-4">ESTRATEGIA IT</p>
            <h3
              class="text-xl font-black uppercase mb-6 group-hover:text-[#FFCC00] leading-tight"
            >
              De IT a negocio: como dejar de ser soporte y volverte estrategico
            </h3>
            <a
              class="inline-flex items-center gap-2 font-label text-label uppercase tracking-widest border-b border-[#FFCC00] pb-1"
              href="/blog/de-it-a-negocio-como-dejar-de-ser-soporte-y-volverte-estrategico"
            >
              ACCEDER <span
                class="material-symbols-outlined text-sm"
                data-icon="arrow_forward">arrow_forward</span
              >
            </a>
          </div>

          <div
            class="bg-[#2A2A2A] industrial-border border-white/20 p-8 hover:border-[#FFCC00] transition-colors group"
          >
            <p class="font-key-concept text-[#FFCC00] mb-4">ARQUITECTURA API</p>
            <h3
              class="text-xl font-black uppercase mb-6 group-hover:text-[#FFCC00] leading-tight"
            >
              Como integrar plataformas que no se hablan entre si
            </h3>
            <a
              class="inline-flex items-center gap-2 font-label text-label uppercase tracking-widest border-b border-[#FFCC00] pb-1"
              href="/blog/como-integrar-plataformas-que-no-se-hablan-entre-si"
            >
              ACCEDER <span
                class="material-symbols-outlined text-sm"
                data-icon="arrow_forward">arrow_forward</span
              >
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
