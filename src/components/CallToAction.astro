<section
    class="bg-[#FFCC00] px-6 sm:px-10 md:px-16 py-20 md:py-32 border-t-4 border-[#1A1A1A] overflow-hidden"
    id="contacto"
>
    <div class="max-w-4xl mx-auto text-center space-y-8 md:space-y-12">
        <!-- Título Adaptable -->
        <h2 class="text-4xl sm:text-6xl lg:text-headline-xl font-bold uppercase text-[#1A1A1A] leading-[0.9]">
            ¿Preparado para el mando?
        </h2>
        
        <!-- Párrafo Adaptable -->
        <p class="text-xl md:text-2xl lg:text-headline-md font-semibold text-[#1A1A1A] max-w-2xl mx-auto">
            Agende una sesión de diagnóstico estructural para su organización.
        </p>
        
        <!-- Formulario Adaptable -->
        <div class="flex flex-col md:flex-row gap-4 md:gap-0 justify-center items-stretch md:items-center">
            <input
                class="bg-white border-4 border-[#1A1A1A] px-6 py-5 md:px-8 md:py-6 text-lg md:text-xl lg:text-headline-md font-bold focus:outline-none w-full md:w-96 placeholder:text-gray-400 md:border-r-0"
                placeholder="EMAIL CORPORATIVO"
                type="email"
            />
            <button
                class="bg-[#1A1A1A] text-white px-8 py-5 md:px-12 md:py-6 text-lg md:text-xl lg:text-headline-md font-bold hover:bg-white hover:text-[#1A1A1A] border-4 border-[#1A1A1A] transition-all shadow-[4px_4px_0px_0px_rgba(26,26,26,1)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none uppercase"
            >
                Solicitar Diagnóstico
            </button>
        </div>
    </div>
</section>