<header
    class="bg-[#FFCC00] text-[#1A1A1A] font-['Space_Grotesk'] font-bold uppercase tracking-tighter border-b-4 border-[#1A1A1A] flex justify-between items-center w-full px-8 md:px-16 py-6 fixed top-0 z-50"
>
    <div class="text-2xl md:text-3xl font-black text-[#1A1A1A] tracking-widest">
        LIDERAZGOTECH
    </div>

    <!-- Botón Menú Móvil -->
    <button
        id="menu-bg"
        class="md:hidden flex items-center justify-center p-2 border-4 border-[#1A1A1A] bg-white text-[#1A1A1A]"
    >
        <span class="material-symbols-outlined text-3xl" id="menu-icon">menu</span>
    </button>

    <!-- Navegación -->
    <nav
        id="nav-menu"
        class="hidden absolute top-full left-0 w-full bg-[#FFCC00] border-b-4 border-[#1A1A1A] flex-col items-center gap-6 py-8 md:static md:w-auto md:bg-transparent md:border-none md:flex md:flex-row md:gap-12 md:py-0"
    >
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/#mision">Misión</a>
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/#servicios">Servicios</a>
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/#metodologia">Metodología</a>
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/sobre-mi/">Sobre Mí</a>
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/recursos/">Recursos</a>
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/blog/">Blog</a>
        <a class="nav-link text-[#1A1A1A] opacity-80 hover:bg-[#1A1A1A] hover:text-white transition-none px-2 py-1 w-full text-center md:w-auto" href="/#contacto">Contacto</a>
    </nav>
</header>

<script>
    const menuBtn = document.getElementById("menu-bg");
    const navMenu = document.getElementById("nav-menu");
    const menuIcon = document.getElementById("menu-icon");
    // Seleccionamos todos los enlaces que tengan la clase nav-link
    const navLinks = document.querySelectorAll(".nav-link");

    // Función reutilizable para abrir/cerrar
    const toggleMenu = () => {
        navMenu?.classList.toggle("hidden");
        navMenu?.classList.toggle("flex");

        if (menuIcon) {
            menuIcon.textContent = menuIcon.textContent === "menu" ? "close" : "menu";
        }
    };

    // Evento para el botón hamburguesa
    menuBtn?.addEventListener("click", toggleMenu);

    // Evento para cada enlace (solo actúa si el menú está visible en móvil)
    navLinks.forEach(link => {
        link.addEventListener("click", () => {
            // Solo cerramos si el menú no está oculto (evita bugs en desktop)
            if (!navMenu?.classList.contains("hidden") && window.innerWidth < 768) {
                toggleMenu();
            }
        });
    });
</script>